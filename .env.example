# Handball (NRW-Teams, H4A-API)
# Vollständige Team-ID aus der handball.net URL: handball4all.{verband}.{numericId}
# Verband für NRW: westfalen (HV Westfalen) oder niederrhein (HV Niederrhein)
# Beispiel: handball4all.westfalen.1309001
HANDBALL_TEAM_ID=handball4all.westfalen.1309001

# KI (optional – nur für Phase 4 benötigt)
ANTHROPIC_API_KEY=sk-ant-...
