# ═══════════════════════════════════════════════════════════════════════════════
# 🐙 FeedKrake - Konfiguration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Kopiere diese Datei zu ".env" und trage deine Keys ein:
#   cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Discord Webhooks ─────────────────────────────────────────────────────────
# Erstelle Webhooks: Server Settings → Integrations → Webhooks → New Webhook
# Format: DISCORD_WEBHOOK_{CHANNEL_NAME}=url

DISCORD_WEBHOOK_ALLGEMEIN=https://discord.com/api/webhooks/DEIN_WEBHOOK
DISCORD_WEBHOOK_GAMING=https://discord.com/api/webhooks/DEIN_WEBHOOK
DISCORD_WEBHOOK_NEWS=https://discord.com/api/webhooks/DEIN_WEBHOOK
DISCORD_WEBHOOK_HANDBALL=https://discord.com/api/webhooks/DEIN_WEBHOOK
DISCORD_WEBHOOK_STATS=https://discord.com/api/webhooks/DEIN_WEBHOOK
DISCORD_WEBHOOK_TEST=https://discord.com/api/webhooks/DEIN_WEBHOOK

# ─── PUBG API ─────────────────────────────────────────────────────────────────
# API Key von: https://developer.pubg.com/

PUBG_API_KEY=dein-pubg-api-key

# ─── Claude API ───────────────────────────────────────────────────────────────
# API Key von: https://console.anthropic.com/

CLAUDE_API_KEY=sk-ant-api-dein-key

# ─── Battlefield API ──────────────────────────────────────────────────────────

BF6_API_KEY=dein-bf6-api-key
