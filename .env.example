# Handball Statistiken (handballstatistiken.de)
# Format: {BASE_URL}/{leagueId} → vollständige Scraping-URL für Playwright-Fallback
HANDBALL_STATS_BASE_URL=https://handballstatistiken.de/NRW/2526

# KI – Claude-Analyse (!analyse-Command)
ANTHROPIC_API_KEY=sk-ant-...

# Discord Bot – Gateway für Command-Empfang (!analyse)
# Token aus Discord Developer Portal → Anwendung → Bot → Token
# Wichtig: "Message Content Intent" unter Bot → Privileged Gateway Intents aktivieren!
DISCORD_BOT_TOKEN=MTA...
